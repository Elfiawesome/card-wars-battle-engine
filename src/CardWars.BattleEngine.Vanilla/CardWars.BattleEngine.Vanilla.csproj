<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\CardWars.BattleEngine\CardWars.BattleEngine.csproj" />
  </ItemGroup>


  <Target Name="CopyModToVanillaFolder" AfterTargets="Build">
    <ItemGroup>
      <ModOutputFiles Include="$(TargetDir)$(TargetName).dll" />
      <ModOutputFiles Include="$(TargetDir)$(TargetName).pdb" />
    </ItemGroup>
    <Message Text="Copying BattleEngine Vanilla Mod to mods folder..." Importance="high" />
    <Copy SourceFiles="@(ModOutputFiles)" DestinationFolder="$(MSBuildProjectDirectory)\..\..\gamedata\mods\vanilla\code\" />
  </Target>
</Project>
